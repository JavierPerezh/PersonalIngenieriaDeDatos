db.corredores.aggregate([
  { $unwind: "$recorridos" },
  {
    $addFields: {
      mes: { $month: { $dateFromString: { dateString: "$recorridos.fecha" } } },
      año: { $year: { $dateFromString: { dateString: "$recorridos.fecha" } } },
      nombreCompleto: { $concat: ["$nombre", " ", "$apellido"] }
    }
  },
  {
    $group: {
      _id: {
        corredor: "$nombreCompleto",
        año: "$año",
        mes: "$mes"
      },
      promedioMinutos: { $avg: "$recorridos.minutos" }
    }
  },
  {
    $project: {
      _id: 0,
      corredor: "$_id.corredor",
      año: "$_id.año",
      mes: "$_id.mes",
      promedioMinutos: { $round: ["$promedioMinutos", 2] }
    }
  },
  { $sort: { corredor: 1, año: 1, mes: 1 } }
])
