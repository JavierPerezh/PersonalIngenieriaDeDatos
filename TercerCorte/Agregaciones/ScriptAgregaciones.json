db.corredores.aggregate([
  {
    $addFields: {
      totalMinutos: { $sum: "$recorridos.minutos" },
      totalKilometros: { $sum: "$recorridos.km" },
      nombreCompleto: { $concat: ["$nombre", " ", "$apellido"] }
    }
  },
  {
    $project: {
      _id: 0,
      nombreCompleto: 1,
      totalMinutos: 1,
      totalKilometros: 1
    }
  }
])
